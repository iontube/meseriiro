---
import type { BreadcrumbItem } from '../helpers/types';

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const allItems: BreadcrumbItem[] = [
  { label: 'Acasă', href: '/' },
  ...items,
];
---

<nav aria-label="Breadcrumb" class="py-3">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-surface-600">
    {allItems.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && (
          <svg class="w-3.5 h-3.5 text-surface-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href && index < allItems.length - 1 ? (
          <a href={item.href} class="text-surface-600 hover:text-brand-600 transition-colors no-underline">
            {item.label}
          </a>
        ) : (
          <span class="text-surface-800 font-medium" aria-current={index === allItems.length - 1 ? 'page' : undefined}>
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
