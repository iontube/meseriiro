const iconPath = iconMap[domeniu.icon] || iconMap['building'];
---

<a href={`/domenii/${domeniu.slug}/`} class="card group block p-6 no-underline h-full">
  <div class="flex items-start gap-4">
    <div class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center shrink-0 group-hover:bg-brand-100 transition-colors">
      <svg aria-hidden="true" class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
      </svg>
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="text-lg font-heading font-semibold text-surface-900 group-hover:text-brand-600 transition-colors">
        {domeniu.nume}
      </h3>
      <p class="text-sm text-surface-600 mt-1.5 leading-relaxed line-clamp-2">
        {domeniu.descriere}
      </p>
      <p class="text-xs text-brand-600 mt-3 font-semibold">
        {meseriiCount} {meseriiCount === 1 ? 'meserie' : 'meserii'}
      </p>
    </div>
  </div>
</a>
