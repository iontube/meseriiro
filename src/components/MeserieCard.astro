---
import type { Meserie } from '../helpers/types';
import { getDomeniuForMeserie, formatSalariu, getNivelCerereLabel } from '../helpers/data';

interface Props {
  meserie: Meserie;
}

const { meserie } = Astro.props;
const domeniu = getDomeniuForMeserie(meserie);

const cerereColors: Record<string, string> = {
  scazut: 'badge-warning',
  mediu: 'badge-brand',
  ridicat: 'badge-success',
};
---

<article class="card p-6 flex flex-col h-full">
  <div class="flex items-start justify-between gap-3 mb-3">
    <div>
      <h3 class="text-lg font-heading font-semibold text-surface-900 leading-tight">
        <a href={`/meserii/${meserie.slug}/`} class="text-surface-900 no-underline hover:text-brand-600 transition-colors">
          {meserie.nume}
        </a>
      </h3>
      {domeniu && (
        <a href={`/domenii/${domeniu.slug}/`} class="text-xs text-surface-500 hover:text-brand-600 no-underline transition-colors mt-0.5 inline-block">
          {domeniu.nume}
        </a>
      )}
    </div>
    <span class:list={['badge shrink-0', cerereColors[meserie.nivelCerere] || 'badge-brand']}>
      {getNivelCerereLabel(meserie.nivelCerere)}
    </span>
  </div>

  <p class="text-sm text-surface-600 leading-relaxed mb-4 line-clamp-3 flex-1">
    {meserie.descriere}
  </p>

  <div class="flex items-end justify-between pt-3 border-t border-surface-100">
    <div>
      <p class="text-xs text-surface-500 mb-0.5">Salariu mediu</p>
      <p class="text-lg font-heading font-bold text-brand-600">
        {formatSalariu(meserie.salpiuNational.mediu)}
      </p>
    </div>
    <a
      href={`/meserii/${meserie.slug}/`}
      class="btn-secondary text-xs px-3 py-1.5 no-underline"
    >
      Detalii →
    </a>
  </div>
</article>
