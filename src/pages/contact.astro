---
import Layout from '../layouts/Layout.astro';
import SEOHead from '../components/SEOHead.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const breadcrumbs = [{ label: 'Contact' }];
---

<Layout>
  <SEOHead
    slot="head"
    title="Contact - Meseriile.ro"
    description="Contactează echipa Meseriile.ro pentru întrebări, sugestii sau colaborări."
    canonical="/contact/"
  />

  <div class="container-custom">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <article class="container-narrow pb-16 sm:pb-20">
    <div class="max-w-2xl">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-surface-900 mb-4">
        Contact
      </h1>
      <p class="text-lg text-surface-700 leading-relaxed mb-10">
        Ai o întrebare, o sugestie sau vrei să raportezi o eroare? Ne poți contacta prin email.
      </p>

      <div class="card p-8">
        <div class="flex items-start gap-4 mb-8">
          <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h2 class="font-heading font-bold text-surface-900 text-lg mb-1">Email</h2>
            <a href="mailto:contact@meseriile.ro" class="text-brand-600 hover:text-brand-800 font-medium text-lg transition-colors">
              contact@meseriile.ro
            </a>
          </div>
        </div>

        <div class="border-t border-surface-200 pt-6">
          <h3 class="font-heading font-semibold text-surface-900 mb-3">Ne poți scrie pentru:</h3>
          <ul class="space-y-2 text-surface-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Corecții sau actualizări ale datelor salariale</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Sugestii de meserii sau domenii noi</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Raportarea unei erori tehnice</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Solicitări GDPR (acces, ștergere date)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Propuneri de colaborare</span>
            </li>
          </ul>
        </div>
      </div>

      <p class="text-sm text-surface-500 mt-6">
        Încercăm să răspundem în maximum 48 de ore lucrătoare.
      </p>
    </div>
  </article>
</Layout>
