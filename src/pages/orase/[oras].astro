---
import Layout from '../../layouts/Layout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { orase, formatSalariu } from '../../helpers/data';
import { getTopSalaryMeseriiInOras, getOrasSiloLinks, getMeseriiLinksForOras } from '../../helpers/interlinking';
import { buildBreadcrumbSchema, buildOrasPageSchema } from '../../helpers/structured-data';
import type { Oras } from '../../helpers/types';

export function getStaticPaths() {
  return orase.map(o => ({
    params: { oras: o.id },
    props: { oras: o },
  }));
}

interface Props { oras: Oras; }

const { oras } = Astro.props;
const topMeserii = getTopSalaryMeseriiInOras(oras.id, 20);
const alteOrase = getOrasSiloLinks(oras.id);
const meseriiLinks = getMeseriiLinksForOras(oras.id, 10);

const breadcrumbs = [
  { label: 'Orașe', href: '/orase/' },
  { label: oras.nume },
];

const schemaTop = topMeserii.slice(0, 5).map(t => ({ nume: t.meserie.nume, salariuMediu: t.salariu.mediu }));
---

<Layout>
  <SEOHead
    slot="head"
    title={`Salarii în ${oras.nume} ${new Date().getFullYear()} - Top Meserii și Câștiguri`}
    description={`Top meserii plătite în ${oras.nume}: salarii nete actualizate, cerere pe piața muncii și linkuri către detalii pe fiecare profesie.`}
    canonical={`/orase/${oras.id}/`}
    jsonLd={[
      buildBreadcrumbSchema(breadcrumbs),
      buildOrasPageSchema(oras.nume, oras.id, schemaTop),
    ]}
  />

  <div class="container-custom">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <article class="container-narrow pb-16 sm:pb-20">
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="badge badge-brand">{oras.regiune}</span>
        <span class="badge bg-surface-100 text-surface-700">{oras.populatie.toLocaleString('ro-RO')} locuitori</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-surface-900 mb-4">
        Salarii și meserii în {oras.nume}
      </h1>
      <p class="text-lg text-surface-700 leading-relaxed">
        Top {topMeserii.length} meserii plătite în {oras.nume}, cu salarii nete actualizate. Compară cu alte orașe din România.
      </p>
    </header>

    <!-- Top meserii table -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-bold text-surface-900 mb-4">
        Top meserii în {oras.nume} după salariu
      </h2>
      <div class="card p-5 relative">
        <div class="sm:hidden flex items-center gap-1.5 text-xs text-surface-400 mb-2">
          <svg aria-hidden="true" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
          </svg>
          <span>Glisează pentru toate coloanele</span>
        </div>
        <div class="overflow-x-auto scrollbar-thin">
          <table class="w-full text-left text-sm" style="min-width: 520px;">
            <thead>
              <tr class="border-b-2 border-surface-200">
                <th class="pb-3 font-heading font-semibold text-surface-800">#</th>
                <th class="pb-3 font-heading font-semibold text-surface-800">Meserie</th>
                <th class="pb-3 font-heading font-semibold text-surface-800 text-right">Minim</th>
                <th class="pb-3 font-heading font-semibold text-surface-800 text-right">Mediu</th>
                <th class="pb-3 font-heading font-semibold text-surface-800 text-right">Maxim</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-100">
              {topMeserii.map((item, i) => (
                <tr class="hover:bg-surface-50 transition-colors">
                  <td class="py-3 text-surface-400 text-xs font-semibold">{i + 1}</td>
                  <td class="py-3">
                    <a
                      href={`/salariu/${item.meserie.slug}/${oras.id}/`}
                      class="text-surface-800 hover:text-brand-600 no-underline font-medium transition-colors"
                      title={`Salariu ${item.meserie.nume} în ${oras.nume}`}
                    >
                      {item.meserie.nume}
                    </a>
                  </td>
                  <td class="py-3 text-right text-surface-600 tabular-nums">{formatSalariu(item.salariu.min)}</td>
                  <td class="py-3 text-right font-semibold text-surface-900 tabular-nums">{formatSalariu(item.salariu.mediu)}</td>
                  <td class="py-3 text-right text-surface-600 tabular-nums">{formatSalariu(item.salariu.max)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="sm:hidden pointer-events-none absolute top-0 right-0 w-8 h-full bg-gradient-to-l from-white to-transparent rounded-r-card"></div>
      </div>
    </section>

    <!-- Links to salary detail pages -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-bold text-surface-900 mb-4">
        Detalii salariu pe meserie în {oras.nume}
      </h2>
      <div class="grid sm:grid-cols-2 gap-3">
        {topMeserii.slice(0, 10).map(item => (
          <a
            href={`/salariu/${item.meserie.slug}/${oras.id}/`}
            class="card p-4 no-underline group flex items-center justify-between"
            title={`Salariu ${item.meserie.nume} în ${oras.nume}`}
          >
            <span class="font-medium text-surface-800 group-hover:text-brand-600 transition-colors">
              {item.meserie.nume}
            </span>
            <span class="text-sm font-bold text-brand-700 tabular-nums">
              {formatSalariu(item.salariu.mediu)}
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Cross-SILO: Descrieri meserii -->
    {meseriiLinks.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-heading font-bold text-surface-900 mb-4">
          Descrieri meserii disponibile în {oras.nume}
        </h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {meseriiLinks.map(link => (
            <a href={link.href} class="card p-4 no-underline group flex items-center justify-between" title={link.title}>
              <span class="font-medium text-surface-800 group-hover:text-brand-600 transition-colors">{link.text}</span>
              <svg aria-hidden="true" class="w-4 h-4 text-surface-400 group-hover:text-brand-500 transition-colors shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Alte orașe (SILO lateral) -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-bold text-surface-900 mb-4">Alte orașe</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {alteOrase.map(link => (
          <a href={link.href} class="card p-4 no-underline group flex items-center gap-3" title={link.title}>
            <svg aria-hidden="true" class="w-5 h-5 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="font-medium text-surface-800 group-hover:text-brand-600 transition-colors">{link.text}</span>
          </a>
        ))}
        <a href="/orase/" class="card p-4 no-underline group flex items-center gap-3">
          <svg aria-hidden="true" class="w-5 h-5 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
          <span class="font-medium text-brand-600 group-hover:text-brand-700 transition-colors">Toate orașele →</span>
        </a>
      </div>
    </section>

    <!-- Back to all -->
    <div class="card p-5 flex items-center gap-3">
      <svg aria-hidden="true" class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
      </svg>
      <a href="/orase/" class="font-medium text-surface-800 no-underline hover:text-brand-600 transition-colors">
        Înapoi la toate orașele
      </a>
    </div>
  </article>
</Layout>
