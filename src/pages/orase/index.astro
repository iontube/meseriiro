---
import Layout from '../../layouts/Layout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import { orase, meserii, domenii, competente, formatSalariu } from '../../helpers/data';
import { buildBreadcrumbSchema, buildWebPageSchema, buildFAQSchema, buildItemListSchema } from '../../helpers/structured-data';
import { getOraseByRegiune, getTopSalaryMeseriiInOras } from '../../helpers/interlinking';

const currentMonth = new Date().toISOString().slice(0, 10);
const displayDate = new Date().toLocaleDateString('ro-RO', { month: 'long', year: 'numeric' });

const breadcrumbs = [{ label: 'Acasă', href: '/' }, { label: 'Orașe' }];
const oraseByRegiune = getOraseByRegiune();
const regiuni = Object.keys(oraseByRegiune).sort();

// Compute average salary per city
function getAvgSalaryForOras(orasId: string): number {
  const salarii = meserii
    .filter(m => m.salpiuOrase[orasId]?.mediu)
    .map(m => m.salpiuOrase[orasId].mediu);
  if (salarii.length === 0) return 0;
  return Math.round(salarii.reduce((s, v) => s + v, 0) / salarii.length);
}

const oraseStats = orase.map(o => {
  const avgSalary = getAvgSalaryForOras(o.id);
  const topMeseriiOras = getTopSalaryMeseriiInOras(o.id, 1);
  const topMeserie = topMeseriiOras.length > 0 ? topMeseriiOras[0] : null;
  return { oras: o, avgSalary, topMeserie };
}).sort((a, b) => b.avgSalary - a.avgSalary);

const top10BySalary = oraseStats.filter(os => os.avgSalary > 0).slice(0, 10);
const topOras = oraseStats[0];
const bottomOras = oraseStats.filter(os => os.avgSalary > 0).at(-1);
const totalPopulatie = orase.reduce((s, o) => s + o.populatie, 0);
const avgSalariuGlobal = Math.round(oraseStats.filter(os => os.avgSalary > 0).reduce((s, os) => s + os.avgSalary, 0) / oraseStats.filter(os => os.avgSalary > 0).length);
const totalMeserii = meserii.length;

// Build lookup for quick access
const oraseStatsMap = new Map(oraseStats.map(os => [os.oras.id, os]));

const faqItems = [
  {
    intrebare: 'Câte orașe sunt acoperite în acest director?',
    raspuns: `Directorul include date salariale pentru ${orase.length} orașe din România, grupate pe ${regiuni.length} regiuni. Fiecare oraș conține informații despre salariile a ${totalMeserii} de meserii, cu valori minime, medii și maxime.`,
  },
  {
    intrebare: 'Care este orașul cu cele mai mari salarii din România?',
    raspuns: `${topOras.oras.nume} are cel mai mare salariu mediu din director: ${formatSalariu(topOras.avgSalary)}/lună, calculat ca medie a tuturor meseriilor disponibile. ${topOras.topMeserie ? `Cea mai bine plătită meserie în ${topOras.oras.nume} este ${topOras.topMeserie.meserie.nume}, cu ${formatSalariu(topOras.topMeserie.salariu.mediu)}/lună.` : ''}`,
  },
  {
    intrebare: 'Cum sunt calculate salariile pe orașe?',
    raspuns: 'Salariile sunt estimări nete lunare bazate pe oferte de muncă publice, date INS și rapoarte salariale. Pentru fiecare oraș se afișează intervale (minim, mediu, maxim) care pot varia în funcție de experiență, angajator și specificul postului.',
  },
  {
    intrebare: 'Ce diferențe salariale există între orașe?',
    raspuns: `Diferența între cel mai bine plătit oraș (${topOras.oras.nume}: ${formatSalariu(topOras.avgSalary)}) și cel cu salariile cele mai mici (${bottomOras?.oras.nume}: ${formatSalariu(bottomOras?.avgSalary || 0)}) este de ${formatSalariu(topOras.avgSalary - (bottomOras?.avgSalary || 0))}/lună. Factori determinanți: prezența companiilor multinaționale, cererea locală și costul vieții.`,
  },
  {
    intrebare: 'Cum aleg orașul potrivit pentru cariera mea?',
    raspuns: 'Compară salariul mediu din orașul tău cu celelalte, verifică dacă meseria ta are cerere în orașul respectiv și ține cont de costul vieții local. Pagina fiecărui oraș afișează top meseriile plătite și cererea pe piața muncii.',
  },
];
---

<Layout>
  <SEOHead
    slot="head"
    title="Salarii pe Orașe în România - Comparație și Top Meserii"
    ogType="article"
    description={`Compară salariile din ${orase.length} orașe din România, grupate pe ${regiuni.length} regiuni. Top 10 orașe după salariu mediu, de la ${formatSalariu(bottomOras?.avgSalary || 0)} la ${formatSalariu(topOras.avgSalary)}/lună.`}
    canonical="/orase/"
    jsonLd={[
      buildBreadcrumbSchema(breadcrumbs),
      buildWebPageSchema('Salarii pe Orașe în România', `Comparație salarială pe ${orase.length} orașe din România`, '/orase/', { type: 'CollectionPage', dateModified: currentMonth }),
      buildItemListSchema(oraseStats.filter(os => os.avgSalary > 0).map((os, i) => ({ name: os.oras.nume, url: `/orase/${os.oras.id}/`, position: i + 1 }))),
      buildFAQSchema(faqItems),
    ]}
  />

  <div class="container-custom">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Header + Intro -->
  <section class="container-custom pb-10">
    <div class="max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-surface-900 mb-4">
        Salarii pe orașe în România
      </h1>
      <p class="prose-custom text-lg mb-4">
        Directorul acoperă {orase.length} orașe din România cu o populație totală de {totalPopulatie.toLocaleString('ro-RO')} locuitori, grupate pe {regiuni.length} regiuni. Salariul mediu net variază de la {formatSalariu(bottomOras?.avgSalary || 0)}/lună în {bottomOras?.oras.nume} la {formatSalariu(topOras.avgSalary)}/lună în {topOras.oras.nume} — o diferență de {formatSalariu(topOras.avgSalary - (bottomOras?.avgSalary || 0))}.
      </p>
      <p class="prose-custom text-lg">
        Mai jos: top 10 orașe după salariu mediu, toate cele {orase.length} orașe grupate pe regiuni cu populație, cea mai bine plătită meserie și salariu mediu per localitate.
      </p>
      <p class="text-sm text-surface-500 mt-4">
        Actualizat: {displayDate} · Estimări bazate pe oferte de muncă de pe platforme de recrutare, date INS și rapoarte salariale publice.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="container-custom pb-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="card p-5 text-center">
        <p class="stat-value">{orase.length}</p>
        <p class="stat-label">Orașe acoperite</p>
      </div>
      <div class="card p-5 text-center">
        <p class="stat-value">{totalPopulatie.toLocaleString('ro-RO')}</p>
        <p class="stat-label">Populație totală</p>
      </div>
      <div class="card p-5 text-center">
        <p class="stat-value">{formatSalariu(avgSalariuGlobal)}</p>
        <p class="stat-label">Salariu mediu net / lună</p>
      </div>
      <div class="card p-5 text-center">
        <p class="stat-value">{regiuni.length}</p>
        <p class="stat-label">Regiuni geografice</p>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="container-custom pb-10">
    <nav class="card p-6">
      <h2 class="text-lg font-heading font-bold text-surface-900 mb-4">Cuprins — toate orașele pe regiuni</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-4">
        {regiuni.map(regiune => (
          <div>
            <a href={`#${regiune.toLowerCase().replace(/\s+/g, '-').replace(/[ăâ]/g, 'a').replace(/[îș]/g, c => c === 'î' ? 'i' : 's').replace(/ț/g, 't')}`} class="text-sm font-semibold text-brand-600 hover:text-brand-700 no-underline uppercase tracking-wide">
              {regiune}
            </a>
            <div class="mt-1 space-y-0.5">
              {oraseByRegiune[regiune].sort((a, b) => b.populatie - a.populatie).map(oras => {
                const stats = oraseStatsMap.get(oras.id);
                return (
                  <a href={`/orase/${oras.id}/`} class="flex items-center justify-between py-1 text-sm no-underline group border-b border-surface-100 last:border-0">
                    <span class="text-surface-700 group-hover:text-brand-600 transition-colors font-medium">
                      {oras.nume}
                    </span>
                    {stats && stats.avgSalary > 0 && (
                      <span class="text-xs text-surface-500 tabular-nums ml-2 shrink-0">
                        {formatSalariu(stats.avgSalary)}
                      </span>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </nav>
  </section>

  <!-- Top 10 cities by salary -->
  <section class="bg-surface-100 py-12">
    <div class="container-custom">
      <h2 class="section-title mb-6">Top 10 orașe după salariu mediu</h2>
      <div class="space-y-3">
        {top10BySalary.map((os, i) => {
          const maxSalary = top10BySalary[0].avgSalary;
          const barWidth = Math.max(20, Math.round((os.avgSalary / maxSalary) * 100));
          return (
            <a href={`/orase/${os.oras.id}/`} class="card p-4 no-underline group block">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-3">
                  <span class="text-sm font-bold text-surface-400 tabular-nums w-6">{i + 1}.</span>
                  <span class="font-medium text-surface-800 group-hover:text-brand-600 transition-colors">
                    {os.oras.nume}
                  </span>
                </div>
                <span class="text-sm font-bold text-brand-700 tabular-nums shrink-0 ml-3">
                  {formatSalariu(os.avgSalary)}/lună
                </span>
              </div>
              <div class="w-full bg-surface-100 rounded-full h-2">
                <div class="bg-brand-500 h-2 rounded-full transition-all" style={`width: ${barWidth}%`}></div>
              </div>
              <div class="flex items-center gap-4 mt-2 text-xs text-surface-500">
                <span>{os.oras.populatie.toLocaleString('ro-RO')} loc.</span>
                <span>{os.oras.regiune}</span>
                {os.topMeserie && <span>Top: {os.topMeserie.meserie.nume} ({formatSalariu(os.topMeserie.salariu.mediu)})</span>}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- All cities grouped by region -->
  <section class="container-custom py-16 sm:py-20">
    <h2 class="section-title mb-10">Toate orașele pe regiuni</h2>

    {regiuni.map(regiune => {
      const slugRegiune = regiune.toLowerCase().replace(/\s+/g, '-').replace(/[ăâ]/g, 'a').replace(/[îș]/g, c => c === 'î' ? 'i' : 's').replace(/ț/g, 't');
      const oraseRegiune = oraseByRegiune[regiune].sort((a, b) => b.populatie - a.populatie);

      return (
        <div id={slugRegiune} class="mb-14 scroll-mt-8">
          <h3 class="text-2xl font-heading font-bold text-surface-900 mb-4">
            {regiune}
          </h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
            {oraseRegiune.map(oras => {
              const stats = oraseStatsMap.get(oras.id);
              return (
                <a
                  href={`/orase/${oras.id}/`}
                  class="card p-4 no-underline group"
                  title={`Salarii și meserii în ${oras.nume}`}
                >
                  <div class="flex items-center justify-between mb-2">
                    <span class="font-medium text-surface-800 group-hover:text-brand-600 transition-colors">
                      {oras.nume}
                    </span>
                    <svg aria-hidden="true" class="w-4 h-4 text-surface-400 group-hover:text-brand-500 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                  <div class="flex items-center gap-3 text-xs text-surface-500">
                    <span>{oras.populatie.toLocaleString('ro-RO')} loc.</span>
                    {stats && stats.avgSalary > 0 && (
                      <span class="font-semibold text-brand-700 tabular-nums">
                        {formatSalariu(stats.avgSalary)}/lună
                      </span>
                    )}
                  </div>
                  {stats?.topMeserie && (
                    <div class="mt-2 text-xs text-surface-500">
                      Top: {stats.topMeserie.meserie.nume} ({formatSalariu(stats.topMeserie.salariu.mediu)})
                    </div>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
  </section>

  <!-- Cross-silo links -->
  <section class="bg-surface-100 py-12">
    <div class="container-custom">
      <h2 class="section-title mb-6">Continuă pe alte secțiuni</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/domenii/" class="card p-5 no-underline group block">
          <h3 class="font-heading font-semibold text-surface-900 group-hover:text-brand-600 transition-colors mb-1">
            Domenii profesionale
          </h3>
          <p class="text-sm text-surface-600">{domenii.length} sectoare cu meserii, salarii medii și cerere pe piață.</p>
        </a>
        <a href="/meserii/" class="card p-5 no-underline group block">
          <h3 class="font-heading font-semibold text-surface-900 group-hover:text-brand-600 transition-colors mb-1">
            Catalog meserii
          </h3>
          <p class="text-sm text-surface-600">{totalMeserii} profesii cu descriere, responsabilități și studii necesare.</p>
        </a>
        <a href="/salariu/" class="card p-5 no-underline group block">
          <h3 class="font-heading font-semibold text-surface-900 group-hover:text-brand-600 transition-colors mb-1">
            Salarii pe meserii
          </h3>
          <p class="text-sm text-surface-600">Salarii nete pe {orase.length} orașe, cu minim, mediu și maxim per profesie.</p>
        </a>
        <a href="/competente/" class="card p-5 no-underline group block">
          <h3 class="font-heading font-semibold text-surface-900 group-hover:text-brand-600 transition-colors mb-1">
            Competențe cerute
          </h3>
          <p class="text-sm text-surface-600">{competente.length} competențe cu meseriile care le cer și importanța pe piață.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-custom py-16">
    <FAQSection items={faqItems} />
  </section>
</Layout>
